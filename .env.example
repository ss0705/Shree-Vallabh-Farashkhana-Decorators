# Copy this file to .env and replace placeholder values.
# Vite exposes VITE_ values to the browser. Do not put SMTP passwords here.

# Use Nodemailer through the Netlify function.
VITE_MAIL_PROVIDER=nodemailer
VITE_NODEMAILER_ENDPOINT=/.netlify/functions/send-inquiry

# Optional EmailJS fallback. Leave blank if using Nodemailer.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_OWNER_TEMPLATE_ID=
VITE_EMAILJS_CUSTOMER_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Cloudinary unsigned direct upload.
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=farashkhana_unsigned
VITE_CLOUDINARY_FOLDER=shree-vallabh-gallery

# Frontend-only admin gate.
VITE_ADMIN_PASSWORD=admin123

# Add these only in Netlify environment variables, not frontend .env:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM="Shree Vallabh Decorators <your_email@gmail.com>"
# OWNER_EMAIL=owner_email@gmail.com
